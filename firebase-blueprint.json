{
  "entities": {
    "User": {
      "title": "User",
      "description": "General user profile for students, teachers, and parents.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "wilaya": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student", "parent"] },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "createdAt"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Detailed profile for teachers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "levels": { "type": "array", "items": { "type": "string" } },
        "wilaya": { "type": "string" },
        "bio": { "type": "string" },
        "photoUrl": { "type": "string" },
        "certificationUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "plan": { "type": "string", "enum": ["free", "bronze", "silver", "gold"] },
        "planExpiry": { "type": "string", "format": "date-time" },
        "balance": { "type": "number" },
        "totalStudents": { "type": "number" },
        "totalViews": { "type": "number" },
        "rating": { "type": "number" },
        "totalRatings": { "type": "number" },
        "ccp": { "type": "string" },
        "edahabia": { "type": "string" },
        "monthlyPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Student": {
      "title": "Student",
      "description": "Detailed profile for students.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "wilaya": { "type": "string" },
        "level": { "type": "string" },
        "balance": { "type": "number" },
        "points": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "downloadedLessons": { "type": "array", "items": { "type": "string" } },
        "parentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson content.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "level": { "type": "string" },
        "month": { "type": "number" },
        "type": { "type": "string", "enum": ["video", "pdf", "quiz"] },
        "access": { "type": "string", "enum": ["free", "paid"] },
        "price": { "type": "number" },
        "videoUrl": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "duration": { "type": "number" },
        "views": { "type": "number" },
        "allowDownload": { "type": "boolean" },
        "aiSummary": { "type": "string" },
        "aiQuestions": { "type": "array" },
        "lastWatchedPositions": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a student and a teacher.",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "studentName": { "type": "string" },
        "teacherName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "type": { "type": "string", "enum": ["normal", "premium"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "teacherId": { "type": "string" },
        "studentId": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["subscription", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "General user profiles." },
    "/teachers/{teacherId}": { "schema": "Teacher", "description": "Teacher specific profiles." },
    "/students/{studentId}": { "schema": "Student", "description": "Student specific profiles." },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "Lesson content." },
    "/subscriptions/{subId}": { "schema": "object", "description": "Student subscriptions to teachers." },
    "/liveStreams/{liveId}": { "schema": "object", "description": "Live streaming sessions." },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Financial transactions." },
    "/notifications/{userId}/{notifId}": { "schema": "object", "description": "User notifications." },
    "/chats/{chatId}": { "schema": "Chat", "description": "Conversations." },
    "/messages/{messageId}": { "schema": "Message", "description": "Chat messages." }
  }
}
